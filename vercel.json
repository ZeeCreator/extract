{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/extract", "dest": "/api/index.js" },
    { "src": "/proxy", "dest": "/api/index.js" },
    { "src": "/player", "dest": "/api/index.js" },
    { "src": "/embed", "dest": "/api/index.js" },
    { "src": "/health", "dest": "/api/index.js" },
    { "src": "/favicon.ico", "dest": "/api/index.js" }
  ]
}
